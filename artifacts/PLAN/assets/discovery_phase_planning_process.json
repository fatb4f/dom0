{
  "kind": "discovery_phase_planning_process.v1",
  "name": "discovery_phase_planning_process",
  "purpose": "Reusable planning process for discovery-heavy work where evidence can materially change the accepted operational model.",
  "planning_unit": "micro_plan",
  "output_unit": "artifact",
  "promotion_units": [
    "schema_fidelity",
    "applied_control_fidelity"
  ],
  "closure_mode": "temporary_epistemic_quiescence_under_current_evidence",
  "when_to_use": [
    "roots or scope anchors are still hypotheses",
    "ontology is unstable",
    "evidence can materially change the accepted model",
    "control analysis must be rerun when accepted identity changes",
    "one-pass deliverables would hide required reiteration"
  ],
  "state_model": {
    "operational_entities": [
      "runtime_environment",
      "codex_local_agent",
      "codex_cloud_worker",
      "orchestration_daemon"
    ],
    "strata": [
      "ontic_state",
      "evidentiary_state",
      "accepted_relationship_state",
      "accepted_identity_state"
    ],
    "supervisory_states": [
      "applied_control_state",
      "fidelity_review_state"
    ],
    "transition_chain": [
      "ontic_state",
      "evidentiary_state",
      "admission_or_reduction",
      "accepted_relationship_state",
      "accepted_identity_state"
    ],
    "supervisory_overlays": [
      [
        "accepted_identity_state",
        "applied_control_state"
      ],
      [
        "accepted_identity_state",
        "fidelity_review_state"
      ],
      [
        "applied_control_state",
        "fidelity_review_state"
      ]
    ],
    "feedback_path": [
      "applied_control_findings",
      "admission_or_reduction",
      "accepted_relationship_state",
      "accepted_identity_state"
    ]
  },
  "gate_model": [
    {
      "gate": "ingestion",
      "question": "Can this finding enter the evidentiary layer?"
    },
    {
      "gate": "acceptance",
      "question": "Is this evidence strong and coherent enough to mutate accepted relationship or accepted identity state?"
    },
    {
      "gate": "promotion",
      "question": "Does schema fidelity or applied-control fidelity need to be accepted, rejected, or revised?"
    }
  ],
  "anchor_model": {
    "anchor_status": "candidate",
    "examples": [
      "runtime_environment",
      "codex",
      "spawn"
    ],
    "initial_hypotheses": [
      "runtime_environment",
      "codex"
    ],
    "emergent_candidates": [
      "spawn"
    ],
    "allowed_refinements": [
      "confirm",
      "split",
      "merge",
      "reclassify",
      "retire"
    ]
  },
  "fsm_guidance": {
    "role": "local_probe",
    "not_role": "base_ontology",
    "fit_requires": [
      "bounded_named_states",
      "bounded_transitions",
      "guards",
      "controllable_transition_paths",
      "observable_outputs"
    ]
  },
