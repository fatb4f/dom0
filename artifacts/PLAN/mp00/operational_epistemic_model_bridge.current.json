    "evidentiary_state",
    "accepted_relationship_state",
    "accepted_identity_state"
  ],
  "supervisory_states": [
    "applied_control_state",
    "fidelity_review_state"
  ],
  "coupling_rules": [
    "observations_from_operational_entities_enter_evidentiary_state_immediately",
